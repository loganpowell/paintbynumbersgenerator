{
    "compilerOptions": {
        "noImplicitAny": true,
        "strict": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "strictNullChecks": true,
        "removeComments": false,
        "sourceMap": true,
        "target": "es2020",
        "lib": [
            "dom",
            "es2020"
        ],
        "types": ["node"],
        "esModuleInterop": true,
        "skipLibCheck": true
    }
}